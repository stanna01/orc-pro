# ORC PRO - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://orc_user:secure_password_change_me@localhost:5432/orc_pro
SQLALCHEMY_DATABASE_URL=postgresql://orc_user:secure_password_change_me@localhost:5432/orc_pro

# Database settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=orc_user
DB_PASSWORD=secure_password_change_me
DB_NAME=orc_pro

# ============================================
# API CONFIGURATION
# ============================================

# API Server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# API documentation
API_TITLE=ORC Pro - Mining Checklist Digitization
API_VERSION=1.0.0
API_DESCRIPTION=REST API for mining checklist OCR and validation

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

# Secret key for JWT tokens (change this in production!)
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars

# JWT configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
PASSWORD_HASH_ALGORITHM=bcrypt

# ============================================
# REDIS CONFIGURATION (for production)
# ============================================

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# CELERY CONFIGURATION
# ============================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# ============================================
# MACHINE LEARNING MODELS
# ============================================

# Model cache directory
MODEL_CACHE_DIR=./models

# TrOCR Configuration
TROCR_MODEL=microsoft/trocr-large-handwritten
TROCR_PROCESSOR=microsoft/trocr-large-handwritten
TROCR_DEVICE=cpu

# Model parameters
OCR_CONFIDENCE_THRESHOLD=0.75
OCR_BATCH_SIZE=8
OCR_MAX_WORKERS=4

# ============================================
# TESSERACT OCR (Backup OCR)
# ============================================

# Path to Tesseract executable
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux: /usr/bin/tesseract
# Mac: /usr/local/bin/tesseract
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Upload directory
UPLOAD_DIR=./uploads

# Maximum file size (in MB)
MAX_FILE_SIZE=50

# Allowed file extensions
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf,.tiff

# Image preprocessing settings
IMAGE_QUALITY_THRESHOLD=0.5
MIN_IMAGE_DIMENSION=800

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file location
LOG_FILE=./logs/app.log
LOG_ERROR_FILE=./logs/error.log
LOG_OCR_FILE=./logs/ocr.log
LOG_AUDIT_FILE=./logs/audit.log

# Log format
LOG_FORMAT=json

# Max log file size (MB) before rotation
LOG_MAX_SIZE=100

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# ============================================
# MONITORING & METRICS
# ============================================

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Application metrics
TRACK_API_METRICS=true
TRACK_OCR_METRICS=true
TRACK_DATABASE_METRICS=true

# ============================================
# EMAIL CONFIGURATION (for alerts)
# ============================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=orc-pro@example.com
ALERT_EMAIL=admin@example.com

# ============================================
# ENVIRONMENT SETTINGS
# ============================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (set to False in production)
DEBUG=True

# CORS settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application timezone
TIMEZONE=UTC

# Language
LANGUAGE=en

# Default pagination size
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# FORM CONFIGURATION
# ============================================

# Mining operation settings
MINING_OPERATION_NAME=Your Mining Operation
MINING_LOCATION=Your Location

# Shift settings
SHIFT_DURATION_HOURS=12
ALLOW_NIGHT_SHIFT_ROLLOVER=true

# No-go item handling
NO_GO_ITEM_MANDATORY_REMARKS=true
NO_GO_REQUIRES_SUPERVISOR_REVIEW=true

# ============================================
# PERFORMANCE TUNING
# ============================================

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Cache TTL (Time To Live in seconds)
CACHE_TTL=3600

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# API rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# ============================================
# BACKUP & DATA RETENTION
# ============================================

# Database backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_LOCATION=./backups
BACKUP_RETENTION_DAYS=30

# Data retention (days)
LOG_RETENTION_DAYS=90
UPLOAD_FILE_RETENTION_DAYS=365

# ============================================
# EXPERIMENTAL FEATURES
# ============================================

# Enable experimental features
EXPERIMENTAL_FEATURES=false

# Feature flags
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_PREDICTIVE_MAINTENANCE=false
FEATURE_MOBILE_APP=false

# ============================================
# EXTERNAL SERVICES
# ============================================

# Cloud storage (optional)
CLOUD_STORAGE_ENABLED=false
CLOUD_PROVIDER=s3  # s3, gcs, azure
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# Slack notifications (optional)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#orc-pro-alerts

# ============================================
# DEVELOPMENT SETTINGS (DEV ONLY)
# ============================================

# Test database (for running tests)
TEST_DATABASE_URL=sqlite:///./test.db

# Sample data path
SAMPLE_DATA_PATH=./data/samples

# Model download cache
MODEL_CACHE_OFFLINE=false

# ============================================
# Notes
# ============================================

# 1. CHANGE SECRET_KEY IMMEDIATELY IN PRODUCTION
#    Use: python -c "import secrets; print(secrets.token_urlsafe(32))"

# 2. NEVER commit this file to version control
#    Keep .env in .gitignore

# 3. For PostgreSQL setup, run:
#    psql -U postgres -c "CREATE DATABASE orc_pro;"
#    psql -U postgres -c "CREATE USER orc_user WITH PASSWORD 'secure_password';"
#    psql -U postgres -c "GRANT ALL PRIVILEGES ON DATABASE orc_pro TO orc_user;"

# 4. Install Tesseract from:
#    https://github.com/UB-Mannheim/tesseract/wiki

# 5. Create required directories:
#    mkdir -p logs uploads models backups data/samples
